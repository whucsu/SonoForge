{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pytest",
      "type": "shell",
      "command": "bash ${workspaceFolder}/scripts/run_tests.sh -q",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "ruff check",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/ruff check src tests",
      "problemMatcher": []
    },
    {
      "label": "run app",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python -m echo_personal_tool",
      "options": {
        "env": {
          "PYTHONPATH": "${workspaceFolder}/src"
        }
      },
      "problemMatcher": []
    }
  ]
}
