def test_environment():
    print("Тест окружения Python:")
    print("----------------------")
    
    # Проверка версии Python
    import sys
    print(f"Версия Python: {sys.version}")
    print(f"Версия Python (детально): {sys.version_info}")
    
    # Проверка доступных библиотек
    try:
        import numpy as np
        print(f"NumPy установлен: версия {np.__version__}")
    except ImportError:
        print("NumPy не установлен!")
    
    try:
        import pandas as pd
        print(f"Pandas установлен: версия {pd.__version__}")
    except ImportError:
        print("Pandas не установлен!")
    
    try:
        import matplotlib
        print(f"Matplotlib установлен: версия {matplotlib.__version__}")
    except ImportError:
        print("Matplotlib не установлен!")
    
    print("\nТест завершён!")

if __name__ == "__main__":
    test_environment()
